# ── Core (required) ───────────────────────────────────────────────────────────
# Postgres connection string. For Docker Compose this is set automatically.
DATABASE_URL=postgresql://postgres:support@localhost:5432/support_tool
# when use docker use postgres instead of localhost, like this:
#  DATABASE_URL=postgresql://postgres:support@postgres:5432/support_tool

# Session/crypto secret — MUST be at least 32 random characters.
APP_SECRET=replace-with-at-least-32-random-characters
# Public base URL of this instance (used in email links). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (SMTP) — optional ───────────────────────────────────────────────────
# Without these, email sends are logged by the worker instead of delivered.
# Works with any SMTP provider: Mailtrap, SendGrid, Postmark, AWS SES, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── Google OAuth — optional ───────────────────────────────────────────────────
# Enables the "Continue with Google" button on the agent/admin login.
# Leave blank to use magic-link sign-in only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Pusher Beams (browser/OS push) — optional ─────────────────────────────────
# Sends OS-level push notifications to agents when a customer replies — even when
# the app is closed. Leave blank to use the in-app notification bell only.
# Get these from https://dashboard.pusher.com → Beams.
# NOTE: NEXT_PUBLIC_* is read by the browser and is baked in at BUILD time
#       (pass it as a build arg for Docker — see README).
NEXT_PUBLIC_PUSHER_BEAMS_INSTANCE_ID=
PUSHER_BEAMS_SECRET_KEY=

# ── Pusher Channels (real-time ticket updates) — optional ────────────────────
# A DIFFERENT Pusher product from Beams above (pub/sub, not push). When set, the
# agent ticket list and an open ticket detail page update live — no refresh
# needed. Leave blank and both pages just work as normal (manual refresh).
# Get these from https://dashboard.pusher.com → Channels (a new "Channels" app,
# not the Beams instance above).
# NOTE: NEXT_PUBLIC_* is read by the browser and is baked in at BUILD time
#       (pass it as a build arg for Docker — see README).
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ── Email Webhook — optional ──────────────────────────────────────────────────
# Set to receive delivery events from your SMTP provider.
# Accepts Authorization: Bearer <secret> or x-webhook-secret header.
# EMAIL_WEBHOOK_SECRET=

# ── File Storage — optional ───────────────────────────────────────────────────
# Default is "local": ticket attachments go to ./uploads on local disk. That's
# all you need for local dev. In Docker, ./uploads MUST be a persistent
# volume or a redeploy wipes every uploaded file — docker-compose.yml already
# mounts one; see docs/file-uploads.md if you deploy any other way.
#
# Set STORAGE_DRIVER=s3 or =r2 to use cloud object storage instead — survives
# host loss, works across multiple app replicas. Uncomment the matching block.
# STORAGE_DRIVER=local

# --- s3 (also covers any S3-compatible provider) ---
# STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# Credentials come from the standard AWS chain (env vars below, IAM role, or
# a shared profile) — not a Support Tool-specific var.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- r2 (Cloudflare R2) ---
# STORAGE_DRIVER=r2
# R2_BUCKET=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Optional for either cloud driver: a CDN/custom domain bound to the bucket.
# Support Tool always serves files through its own /api/files/[...key] route
# regardless of driver, so this only matters if you point other tooling at
# the bucket directly.
# STORAGE_PUBLIC_BASE_URL=
